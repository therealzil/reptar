name: Release - BFI Forensic Bundle

on:
  push:
    tags:
      - 'v*'
  workflow_dispatch:

env:
  PYTHON_VERSION: "3.12"
  FORENSIC_FILENAME: "forensic_runs_release.jsonl"
  BOOTSTRAP_SAMPLES: "10000"

jobs:
  release:
    name: Release forensic bundle
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository (full history)
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Python ${{ env.PYTHON_VERSION }}
        uses: actions/setup-python@v4
        with:
          python-version: ${{ env.PYTHON_VERSION }}

      - name: Cache pip
        uses: actions/cache@v4
        with:
          path: ~/.cache/pip
          key: ${{ runner.os }}-pip-${{ hashFiles('**/requirements.txt') }}
          restore-keys: |
            ${{ runner.os }}-pip-

      - name: Install system dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y --no-install-recommends \
            build-essential gfortran libatlas-base-dev gnupg
          sudo rm -rf /var/lib/apt/lists/*

      - name: Install Python dependencies
        run: |
          python -m pip install --upgrade pip setuptools wheel
          if [ -f requirements.txt ]; then
            pip install --no-cache-dir -r requirements.txt
          else
            pip install --no-cache-dir pytest scipy pandas requests pyyaml
          fi

      - name: Run pytest (release)
        id: pytest_release
        run: |
          pytest -q | tee pytest_output_release.txt

      - name: Run compute_bfi (full bootstrap)
        id: compute_release
        run: |
          python compute_bfi.py data/calibration/toy_dataset.csv --forensic-log "${{ env.FORENSIC_FILENAME }}" --bootstrap "${{ env.BOOTSTRAP_SAMPLES }}"

      - name: Compute file-level SHA256
        id: sha
        run: |
          sha256sum "${{ env.FORENSIC_FILENAME }}" | awk '{print $1}' > "${{ env.FORENSIC_FILENAME }}.sha256"
          echo "FILE_SHA256=$(cat ${FORENSIC_FILENAME}.sha256)" >> $GITHUB_ENV
        shell: bash

      - name: Import GPG private key (with passphrase) and sign forensic file
        if: ${{ secrets.GPG_PRIVATE_KEY != '' && secrets.GPG_PASSPHRASE != '' }}
        env:
          GPG_PRIVATE_KEY: ${{ secrets.GPG_PRIVATE_KEY }}
          GPG_PASSPHRASE: ${{ secrets.GPG_PASSPHRASE }}
          FORENSIC_FILENAME: ${{ env.FORENSIC_FILENAME }}
        run: |
          set -euo pipefail

          export GNUPGHOME="$(mktemp -d)"
          chmod 700 "$GNUPGHOME"
          echo "Using GNUPGHOME: $GNUPGHOME"

          # Decode and import private key (secret must be base64-encoded)
          echo "$GPG_PRIVATE_KEY" | base64 --decode > /tmp/gpg_private.key
          gpg --batch --import /tmp/gpg_private.key

          # Extract fingerprint of the first secret key imported
          KEY_FPR=$(gpg --with-colons --list-secret-keys | awk -F: '/^sec/ {print $5; exit}')
          if [ -z "$KEY_FPR" ]; then
            echo "ERROR: no secret key found after import" >&2
            rm -f /tmp/gpg_private.key
            exit 2
          fi
          echo "Imported key fingerprint: $KEY_FPR"

          # Create detached ASCII-armored signature using loopback pinentry and passphrase
          gpg --batch --yes --pinentry-mode loopback \
              --passphrase "$GPG_PASSPHRASE" \
              --armor --detach-sign --local-user "$KEY_FPR" \
              --output "${FORENSIC_FILENAME}.sig" "${FORENSIC_FILENAME}"

          echo "Signature created: ${FORENSIC_FILENAME}.sig"
          echo "=== Signature preview (first 5 lines) ==="
          head -n 5 "${FORENSIC_FILENAME}.sig" || true

          rm -f /tmp/gpg_private.key
          rm -rf "$GNUPGHOME"
        shell: bash

      - name: Fallback signing step (no GPG key present)
        if: ${{ secrets.GPG_PRIVATE_KEY == '' || secrets.GPG_PASSPHRASE == '' }}
        run: |
          echo "GPG_PRIVATE_KEY or GPG_PASSPHRASE not provided; generating an unsigned placeholder file."
          echo "UNSIGNED" > "${{ env.FORENSIC_FILENAME }}.sig"
        shell: bash

      - name: Verify forensic integrity
        run: |
          python3 verify_forensic.py "${{ env.FORENSIC_FILENAME }}"
        shell: bash

      - name: Upload forensic bundle artifacts
        uses: actions/upload-artifact@v4
        with:
          name: bfi-release-bundle-${{ github.run_id }}
          path: |
            ${{ env.FORENSIC_FILENAME }}
            ${{ env.FORENSIC_FILENAME }}.sha256
            ${{ env.FORENSIC_FILENAME }}.sig
            pytest_output_release.txt
          retention-days: 90

      - name: Output metadata to workflow summary
        if: always()
        run: |
          echo "Forensic bundle generated:" 
          echo " - file: ${{ env.FORENSIC_FILENAME }}"
          echo " - sha256 file: ${{ env.FORENSIC_FILENAME }}.sha256"
          echo " - signature file: ${{ env.FORENSIC_FILENAME }}.sig"
          echo "Artifact name: bfi-release-bundle-${{ github.run_id }}"
        shell: bash

      - name: Optional: print first forensic JSONL line (for logs)
        if: always()
        run: |
          echo "=== Forensic JSONL (first line) ==="
          head -n 1 "${{ env.FORENSIC_FILENAME }}" || true
        shell: bash